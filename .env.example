# --- Operator Data Migration Agent ---
# This service owns its OWN database and job queue. It must never point at the
# operator platform's database. DATABASE_URL is the migration service DB only.

# Postgres connection for the migration service (also hosts the pg-boss queue schema)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/operator_migration?schema=public"

# HTTP API
PORT=3001
HOST=0.0.0.0

# Logging: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Where uploaded raw artifacts (CSV/XLSX bytes) are stored on disk for MVP.
# Swappable for S3/GCS later behind the ArtifactStore port.
ARTIFACT_DIR=./.artifacts

# Postgres schema namespace used by pg-boss for its queue tables.
PGBOSS_SCHEMA=pgboss

# Shared secret for service-to-service auth (Authorization: Bearer <token>).
# Must be >= 16 chars. Generate a strong value per environment, e.g.:
#   openssl rand -hex 32
SERVICE_AUTH_TOKEN=dev-only-change-me-0123456789abcdef

# Publisher selection: "stub" (default, in-memory) or "http" (real platform API).
PUBLISHER=stub
# Required when PUBLISHER=http:
# OPERATOR_IMPORT_BASE_URL=https://platform.example.com
# OPERATOR_IMPORT_TOKEN=your-service-token
# OPERATOR_IMPORT_TIMEOUT_MS=10000

# Node environment
NODE_ENV=development
